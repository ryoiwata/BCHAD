# BCHAD Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# === Required ===

# PostgreSQL connection string
BCHAD_DATABASE_URL=postgres://bchad:bchad@localhost:5432/bchad?sslmode=disable

# Valkey (Redis-compatible) host:port
BCHAD_VALKEY_URL=localhost:6379

# S3/MinIO endpoint (use http://localhost:9000 for local dev)
BCHAD_S3_ENDPOINT=http://localhost:9000

# S3/MinIO credentials (use minioadmin/minioadmin for local dev)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# S3 bucket names
BCHAD_S3_BUCKET_PROFILES=bchad-codebase-profiles
BCHAD_S3_BUCKET_ARTIFACTS=bchad-artifacts

# Temporal server host:port
BCHAD_TEMPORAL_HOST=localhost:7233

# Temporal namespace
BCHAD_TEMPORAL_NAMESPACE=bchad

# Anthropic Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Voyage AI API key — get from https://dash.voyageai.com
VOYAGE_API_KEY=

# GitHub token for repo access and PR creation
# Needs: repo, workflow scopes
GITHUB_TOKEN=

# === Optional ===

# Log level: debug, info, warn, error (default: info)
BCHAD_LOG_LEVEL=info

# Pause pipeline if projected cost exceeds this amount in USD (default: 10.00)
BCHAD_COST_THRESHOLD=10.00

# Tier 2 integration gate timeout (default: 15m)
BCHAD_TIER2_TIMEOUT=15m
